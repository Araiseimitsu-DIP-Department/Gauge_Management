# Application environment.
APP_ENV=local
APP_NAME=ピンゲージ管理

# Database backend selection.
# access  : existing Access database
# postgres: future PostgreSQL backend
DB_BACKEND=access

# Access database folder path.
# You may also set the full .accdb path.
# Fixed file name: ピンゲージ管理.accdb
ACCESS_DB_DIRECTORY=C:\Path\To\AccessFolder

# PostgreSQL skeleton settings.
# Enable only after installing a PostgreSQL driver.
# POSTGRES_CONNECTION_URL=postgresql://user:password@localhost:5432/pingauge
# POSTGRES_SCHEMA=public
