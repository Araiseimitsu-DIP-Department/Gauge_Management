# Application environment.
APP_ENV=local
APP_NAME=ピンゲージ管理

# Database backend selection.
# access  : existing Access database
# postgres: PostgreSQL backend
DB_BACKEND=access

# Access database folder path.
# You may also set the full .accdb path.
# Fixed file name: ピンゲージ管理DB.accdb
ACCESS_DB_DIRECTORY=C:\Path\To\AccessFolder

# PostgreSQL settings.
# POSTGRES_CONNECTION_URL=postgresql://user:password@192.168.1.120:5432/pingauge_management_db
# DATABASE_URL is also accepted for compatibility with migration tooling.
# DATABASE_URL=postgresql://user:password@192.168.1.120:5432/pingauge_management_db
# POSTGRES_SCHEMA=public
